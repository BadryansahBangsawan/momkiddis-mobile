{
  "name": "momkiddis",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.91.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:generate": "turbo -F @momkiddis/db db:generate",
    "deploy": "turbo -F @momkiddis/infra deploy",
    "destroy": "turbo -F @momkiddis/infra destroy"
  },
  "dependencies": {
    "@momkiddis/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@momkiddis/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.12"
}
